{
  "name": "@jaggerxtrm/zsh-starship-config",
  "version": "4.0.0",
  "description": "Modern Zsh + Starship + Nerd Fonts setup via npm",
  "main": "src/index.js",
  "bin": {
    "zsh-starship-config": "./bin/zsc.js",
    "zsc": "./bin/zsc.js"
  },
  "scripts": {
    "start": "node ./bin/zsc.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "build": "npm run build:cli",
    "build:cli": "babel src -d dist",
    "prepublishOnly": "npm test && npm run lint",
    "dev": "node ./bin/zsc.js"
  },
  "keywords": [
    "zsh",
    "starship",
    "cli",
    "terminal",
    "customization",
    "installer",
    "configuration",
    "tmux",
    "fonts",
    "shell"
  ],
  "author": "Dawid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jaggerxtrm/zsh-starship-config.git"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "figlet": "^1.7.0",
    "ora": "^8.0.1",
    "axios": "^1.6.0",
    "semver": "^7.5.4",
    "fs-extra": "^11.1.1",
    "shelljs": "^0.8.5",
    "inquirer": "^9.2.12",
    "progress": "^2.0.3",
    "adm-zip": "^0.5.10",
    "node-downloader-helper": "^2.1.9"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.0",
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "files": [
    "bin/",
    "src/",
    "dist/",
    "data/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
